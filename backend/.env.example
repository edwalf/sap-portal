# ============================================================
#  SAP PORTAL — CONFIGURACIÓN
#  Copia este archivo como .env y completa los valores reales
# ============================================================

# --- SAP Business One Service Layer ---
SAP_HOST=192.168.1.100          # IP o hostname del servidor SAP B1
SAP_PORT=50000                  # Puerto del Service Layer (default: 50000)
SAP_COMPANY=MI_EMPRESA_SA       # Nombre de la base de datos (CompanyDB)
SAP_USER=manager                # Usuario SAP B1
SAP_PASSWORD=tu_password_sap    # Contraseña SAP B1
SAP_HTTPS=true                  # true si usa HTTPS (recomendado)

# --- Seguridad del portal ---
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura_2024
JWT_EXPIRES_IN=8h               # Duración de sesión

# --- Servidor Express ---
PORT=3000
NODE_ENV=production

# --- Usuarios del portal (portal_user:bcrypt_hash) ---
# Para generar un hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('tu_password',10))"
# Los hashes de abajo corresponden a las contraseñas del README
PORTAL_USERS=admin:$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LnY4ozPy7eO,ventas:$2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC.CLUJCmxH9lyOfGLy.,gerente:$2a$10$T8DWDPiP1qFgSqXFCmCXhe5yCRi8vMnmpnrIeGu7TtRsNpWJvvVBm
